# Sarvam AI API Key (get from https://dashboard.sarvam.ai)
# Accepts NEEV_SARVAM_API_KEY or SARVAM_API_KEY (NEEV_ prefix takes priority)
NEEV_SARVAM_API_KEY=

# STT Provider: sarvam (default)
NEEV_STT_PROVIDER=sarvam

# TTS Provider: sarvam | edge (default: edge)
NEEV_TTS_PROVIDER=edge

# Audio settings
NEEV_SAMPLE_RATE=16000
NEEV_SILENCE_THRESHOLD=0.03
NEEV_SILENCE_DURATION=1.5

# Anthropic API Key (for enrichment agent)
# Accepts NEEV_ANTHROPIC_API_KEY or ANTHROPIC_API_KEY (NEEV_ prefix takes priority)
NEEV_ANTHROPIC_API_KEY=

# OpenRouter API Key (when llm_provider=openrouter)
# Accepts NEEV_OPENROUTER_API_KEY or OPENROUTER_API_KEY (NEEV_ prefix takes priority)
NEEV_OPENROUTER_API_KEY=

# Claude settings
NEEV_CLAUDE_MODEL=sonnet
NEEV_CLAUDE_TIMEOUT=30

# Discussion log path
NEEV_DISCUSSION_LOG_PATH=~/.neev-voice/disagreements.jsonl
