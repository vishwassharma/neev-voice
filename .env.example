# Sarvam AI API Key (get from https://dashboard.sarvam.ai)
NEEV_SARVAM_API_KEY=

# STT Provider: sarvam (default)
NEEV_STT_PROVIDER=sarvam

# TTS Provider: sarvam | edge (default: edge)
NEEV_TTS_PROVIDER=edge

# Audio settings
NEEV_SAMPLE_RATE=16000
NEEV_SILENCE_THRESHOLD=0.03
NEEV_SILENCE_DURATION=1.5

# Claude settings
NEEV_CLAUDE_MODEL=sonnet
NEEV_CLAUDE_TIMEOUT=30

# Discussion log path
NEEV_DISCUSSION_LOG_PATH=~/.neev-voice/disagreements.jsonl
